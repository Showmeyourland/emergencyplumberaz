        <tr><td style="padding: 0.5rem; border-bottom: 1px solid #eee;">Mortgage payoff</td><td style="text-align: right; padding: 0.5rem; border-bottom: 1px solid #eee;">-$180,000</td><td style="padding: 0.5rem; border-bottom: 1px solid #eee;">From seller proceeds</td></tr>
        <tr><td style="padding: 0.5rem; border-bottom: 1px solid #eee;">HOA back dues</td><td style="text-align: right; padding: 0.5rem; border-bottom: 1px solid #eee;">-$1,500</td><td style="padding: 0.5rem; border-bottom: 1px solid #eee;">From seller proceeds</td></tr>
        <tr><td style="padding: 0.5rem; border-bottom: 1px solid #eee;">Property tax proration (5 months)</td><td style="text-align: right; padding: 0.5rem; border-bottom: 1px solid #eee;">-$1,500</td><td style="padding: 0.5rem; border-bottom: 1px solid #eee;">From seller proceeds (credited to buyer)</td></tr>
        <tr><td style="padding: 0.5rem; border-bottom: 1px solid #eee;">Owner's title insurance</td><td style="text-align: right; padding: 0.5rem; border-bottom: 1px solid #eee;">$1,400</td><td style="padding: 0.5rem; border-bottom: 1px solid #eee;">Buyer (us)</td></tr>
        <tr><td style="padding: 0.5rem; border-bottom: 1px solid #eee;">Escrow fee</td><td style="text-align: right; padding: 0.5rem; border-bottom: 1px solid #eee;">$700</td><td style="padding: 0.5rem; border-bottom: 1px solid #eee;">Buyer (us)</td></tr>
        <tr><td style="padding: 0.5rem; border-bottom: 1px solid #eee;">Recording + doc prep</td><td style="text-align: right; padding: 0.5rem; border-bottom: 1px solid #eee;">$200</td><td style="padding: 0.5rem; border-bottom: 1px solid #eee;">Buyer (us)</td></tr>
        <tr><td style="padding: 0.5rem; border-bottom: 1px solid #eee;">HOA transfer fee</td><td style="text-align: right; padding: 0.5rem; border-bottom: 1px solid #eee;">$400</td><td style="padding: 0.5rem; border-bottom: 1px solid #eee;">Buyer (us)</td></tr>
        <tr style="background: #f3efea;"><td style="padding: 0.6rem; font-weight: 700;">Net to seller</td><td style="text-align: right; padding: 0.6rem; font-weight: 700;">$142,000</td><td style="padding: 0.6rem;">Wired same day</td></tr>
      </tbody>
