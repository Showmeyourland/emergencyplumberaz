---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE } from '../../config';

const posts = [
  {
    slug: "signs-of-a-slab-leak-arizona",
    title: "Signs of a Slab Leak in Arizona (and What to Do)",
    excerpt: "Warm floors, high water bills, the sound of running water with nothing on — how to identify a slab leak in an AZ home and what to do next. Includes hard water context and repair cost ranges.",
    date: "2026-06-15",
  },
  {
    slug: "water-heater-lifespan-hard-water-az",
    title: "How Arizona's Hard Water Shortens Water Heater Life (Tank vs. Tankless)",
    excerpt: "Phoenix metro water runs 200–300 ppm hardness. Here's what that does to your water heater over time, and how to choose between tank and tankless for AZ conditions.",
    date: "2026-06-15",
  },
  {
    slug: "what-to-do-burst-pipe-before-plumber-arrives",
    title: "What to Do When a Pipe Bursts Before the Plumber Arrives",
    excerpt: "Step-by-step: find the shutoff, limit electrical risk, triage the damage. What to do in the first 20 minutes after a pipe bursts in an Arizona home.",
    date: "2026-06-15",
  },
  {
    slug: "cast-iron-pipe-failure-older-az-homes",
    title: "Cast Iron Pipe Failure in Older Arizona Homes: Why Pre-1980 Phoenix and Tucson Homes Get Sewer Backups",
    excerpt: "Pre-1980 Phoenix and Tucson homes often have corroding cast iron sewer lines. What causes failure in Arizona soil, how to spot the warning signs, and your replacement options.",
    date: "2026-06-15",
  },
  {
    slug: "emergency-plumber-cost-arizona",
    title: "Emergency Plumber Cost in Arizona: Honest Pricing Guide (2026)",
    excerpt: "What emergency plumbers actually charge in Phoenix and Tucson: service call fees, after-hours surcharges, common repair ranges, and how to spot bait pricing before it hits you.",
    date: "2026-06-15",
  },
  {
    slug: "tankless-vs-tank-water-heater-arizona",
    title: "Tankless vs. Tank Water Heater in Arizona: The Full Comparison",
    excerpt: "Upfront cost, 10-year economics, lifespan in hard water, installation requirements, and which type makes more sense for your household. Honest comparison for AZ conditions.",
    date: "2026-06-15",
  },
  {
    slug: "how-to-prevent-monsoon-sewer-backups",
    title: "How to Prevent Monsoon Sewer Backups in Arizona",
    excerpt: "Arizona monsoon rains overwhelm sewer mains and back sewage into homes. Backwater valves, pre-season camera inspections, downspout disconnection, and what to do if a backup happens.",
    date: "2026-06-15",
  },
];
---
<BaseLayout
  title="Plumbing Articles & Resources | Coyote 24 Plumbing"
  description="Honest guides on AZ plumbing: slab leaks, hard water, emergency shutoffs, sewer backups, water heaters. Real information from a Phoenix master plumber."
  pageType="trust"
  crumbs={[{ label: "Home", href: "/" }, { label: "Articles" }]}
>
  <section class="container container--narrow">
    <h1>Plumbing Articles &amp; Resources</h1>
    <p style="font-size: 1.15rem; line-height: 1.6;">
      Honest writing on plumbing in Arizona — what actually goes wrong, why it happens here specifically, and what repairs realistically cost. No fluff, no scare tactics.
    </p>
    <p>
      Arizona's hard water, clay soils, monsoon rains, and older housing stock create plumbing failure patterns that differ from the national average. These guides reflect what we actually see on service calls across Phoenix, Scottsdale, Mesa, Chandler, Tempe, Glendale, and Tucson — not generic how-to content written for a climate nothing like ours.
    </p>
    <p>A few starting points depending on what brought you here:</p>
    <ul>
      <li><strong>Suspect a leak under the slab:</strong> Start with <a href="/blog/signs-of-a-slab-leak-arizona/">Signs of a Slab Leak in Arizona</a> — the 7 warning signs and what electronic leak detection costs.</li>
      <li><strong>Water heater failing or nearing end of life:</strong> <a href="/blog/water-heater-lifespan-hard-water-az/">How Arizona's Hard Water Shortens Water Heater Life</a> explains what's happening inside your tank and whether tankless makes sense in AZ.</li>
      <li><strong>Active pipe emergency right now:</strong> <a href="/blog/what-to-do-burst-pipe-before-plumber-arrives/">What to Do When a Pipe Bursts</a> — read this first, then call us.</li>
      <li><strong>Pre-1980 home with recurring drain issues:</strong> <a href="/blog/cast-iron-pipe-failure-older-az-homes/">Cast Iron Pipe Failure in Older AZ Homes</a> explains why older Phoenix and Tucson homes develop sewer backups.</li>
      <li><strong>Want to know what this will cost:</strong> <a href="/blog/emergency-plumber-cost-arizona/">Emergency Plumber Cost in Arizona</a> — service call fees, repair ranges, and how to avoid bait pricing.</li>
    </ul>
    <p>
      Questions or corrections: call <a href={`tel:${SITE.phone}`}>{SITE.phoneDisplay}</a>. You'll reach the owner.
    </p>
    <hr style="margin: 2.5rem 0 1.5rem; border: none; border-top: 1px solid #e8e4dc;" />
    <h2 style="margin-top: 0;">All articles</h2>
    {posts.map((p) => (
      <article style="border-bottom: 1px solid #e5e3dd; padding: 1.4rem 0;">
        <h2 style="margin-top: 0;"><a href={`/blog/${p.slug}/`} style="text-decoration: none; color: var(--color-primary);">{p.title}</a></h2>
        <p style="color: #6a6a6a; font-size: 0.88rem; margin: 0 0 0.5em;">{new Date(p.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</p>
        <p style="margin: 0;">{p.excerpt}</p>
      </article>
    ))}
  </section>
</BaseLayout>
