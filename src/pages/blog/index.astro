    date: "2026-05-24",
  },
  {
    slug: "opendoor-vs-cash-buyer-arizona",
    title: "Opendoor vs Independent Cash Buyer in Arizona — The Real Comparison",
    excerpt: "iBuyer (Opendoor/Offerpad) vs local independent investor. Real fee breakdowns, real timelines, who's right for which seller.",
    date: "2026-05-23",
  },
  {
    slug: "zillow-cash-offers-explained",
    title: "Zillow Cash Offers Explained — Where the Program Went (2026)",
    excerpt: "Zillow Offers shut down in 2021. Redfin Now exited too. Here's where the iBuyer market actually stands in 2026.",
    date: "2026-05-21",
  },
  {
    slug: "cash-offer-vs-listing-math",
    title: "Cash Offer vs. Listing: The Math in 2026",
    excerpt: "What a cash sale actually nets you after closing costs, commissions, repairs, and carrying costs vs. a typical AZ listing.",
    date: "2026-05-20",
  },
  {
    slug: "i-need-to-sell-my-house-fast",
    title: "I Need to Sell My House Fast in Arizona — What Are Your Real Options?",
    excerpt: "Realistic fast-sale options for AZ. Cash buyers, iBuyers, FSBO with flat-fee MLS, traditional listing. What works for which timeline.",
    date: "2026-05-19",
  },
  {
    slug: "companies-that-buy-houses-for-cash-arizona",
    title: "Companies That Buy Houses for Cash in Arizona — The 2026 Landscape",
    excerpt: "The complete 2026 directory of AZ cash home buying companies. iBuyers, franchises, local investors, aggregators. Who's real, who pays best.",
    date: "2026-05-17",
  },
  {
    slug: "sell-house-during-probate-arizona",
    title: "Selling a House in Probate in Arizona — Complete 2026 Guide",
    excerpt: "How to sell an inherited or estate property through probate court in AZ. Timeline, costs, executor authority, cash sale options.",
    date: "2026-05-16",
  },
  {
    slug: "what-cash-buyers-actually-pay",
    title: "What 'We Buy Houses' Companies Actually Pay (With Real Ranges)",
    excerpt: "65-80% of after-repair-value is the industry standard. Here's how that math works on a typical AZ house.",
    date: "2026-05-15",
  },
