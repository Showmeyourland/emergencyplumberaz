---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE } from '../../config';

const posts = [
  {
    slug: "arizona-wholesale-buyer-disclosure-ars-44-5101",
    title: "Arizona's Wholesale Buyer Disclosure Law (ARS § 44-5101) Explained",
    excerpt: "What AZ's 2022 wholesale-buyer disclosure law actually requires. For homeowners selling to investors — protects both sides if you know it.",
    date: "2026-05-27",
  },
  {
    slug: "closing-cost-breakdown-arizona-cash-sale",
    title: "Closing Cost Breakdown for an Arizona Cash Sale (Every Line Item)",
    excerpt: "Every fee, every deduction, every line on the closing statement. Title fees, escrow, recording, prorations, HOA — and which ones we pay.",
    date: "2026-05-26",
  },
  {
    slug: "best-cash-home-buyers-phoenix",
    title: "9 Best Cash Home Buyers in Phoenix, Arizona (2026 Honest Review)",
    excerpt: "An honest comparison of every active Phoenix cash home buyer in 2026. iBuyers, franchises, local investors. Real pros, cons, offer ranges.",
    date: "2026-05-25",
  },
