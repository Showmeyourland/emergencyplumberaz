---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE } from '../../config';
import { CITY_CONTENT } from '../../data/cityContent';
import { rotateCTA } from '../../utils/cta';
import { buildCityMetaDescription } from '../../utils/meta';

export function getStaticPaths() {
  return SITE.cities.map((c) => ({
    params: { city: c.slug },
    props: { city: c },
  }));
}

const { city } = Astro.props;
const content = CITY_CONTENT[city.slug];
const cta = rotateCTA(city.slug);

const cityFaqsForSchema = content.cityFaqs.concat([
  { q: "How fast can you get here?", a: "For true emergencies we target a fast response — most metro calls are reached within the hour, with longer drive times to outlying areas, which we tell you honestly when you call. If water is actively flowing, we coach you to shut the main while the truck is en route." },
  { q: "Do you charge to come out?", a: "We charge a flat dispatch fee that we quote before the truck rolls — no surprises at the door. The repair itself is priced on a flat-rate schedule by job type, not an open-ended hourly clock, and we get your written approval on the price before any work begins." },
]);

const cityPageSchema = {
  "@context": "https://schema.org",
  "@type": "Plumber",
  "@id": `${SITE.baseUrl}/${city.slug}/#service`,
  "name": `${SITE.brandName} — ${city.name}, AZ`,
  "areaServed": { "@type": "City", "name": city.name, "containedInPlace": { "@type": "State", "name": "Arizona" } },
  "provider": { "@id": `${SITE.baseUrl}/#org` },
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": cityFaqsForSchema.map(f => ({
    "@type": "Question",
    "name": f.q,
    "acceptedAnswer": { "@type": "Answer", "text": f.a },
  })),
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": SITE.baseUrl },
    { "@type": "ListItem", "position": 2, "name": city.name, "item": `${SITE.baseUrl}/${city.slug}/` },
  ],
};

const otherCities = SITE.cities.filter((c) => c.slug !== city.slug).slice(0, 8);

// Plumbing sub-vertical card blurbs, keyed by AZ Emergency Plumbing Co.'s actual subVertical slugs
const SUBVERTICAL_BLURBS = {
  "burst-pipe": "Active leak or burst line — we stop the water and make a permanent repair.",
  "water-heater": "No hot water or a leaking tank — repair or same-day replacement.",
  "drain-clog": "Slow drains, backups, and sewer-line blockages cleared and camera-inspected.",
  "leak-detection": "Slab leaks pinpointed with acoustic and electronic detection, then rerouted or repaired.",
  "gas-line": "Gas leaks and gas-line repair handled with combustible-gas detection and safety testing.",
  "garbage-disposal": "Jammed, leaking, or dead disposals repaired or replaced.",
};
---
<BaseLayout
  title={`Emergency Plumber ${city.name}, AZ — 24-Hour Service | ${SITE.brandName}`}
  description={buildCityMetaDescription(city.name, content.marketNote)}
  pageType="city"
  schema={[cityPageSchema, faqSchema, breadcrumbSchema]}
  crumbs={[
    { label: "Home", href: "/" },
    { label: city.name },
  ]}
>
  <section class="hero">
    <div class="container">
      <span class="hero__kicker">{city.county} County · Pop. {city.pop}</span>
      <h1>Emergency Plumber in {city.name}, Arizona — 24-Hour Service</h1>
      <p class="hero__sub">
        Real plumbers, real trucks, real pricing. Burst pipes, water heaters, drain backups, slab leaks — we answer live and quote before we work. Serving {city.name} around the clock.
      </p>
      <a href={`tel:${SITE.phone}`} class="btn btn--large">{cta}</a>
    </div>
  </section>

  <section class="container container--narrow">
    <span class="section-eyebrow">{city.name} plumbing</span>
    <h2 style="margin-top:0;">{city.name} is one of our regular service areas</h2>
    <p>{content.opener}</p>
    <p><strong>Local context:</strong> {content.marketNote}</p>
  </section>

  {content.marketStats && (
    <section class="container">
      <div class="stat-row">
        <div class="stat-cell">
          <span class="stat-cell__number" style="font-size: 1.35rem;">{content.marketStats.medianPrice}</span>
          <p class="stat-cell__label">Local water / climate profile</p>
        </div>
        <div class="stat-cell">
          <span class="stat-cell__number stat-cell__number--accent" style="font-size: 1.35rem;">{content.marketStats.avgDOM}</span>
          <p class="stat-cell__label">Typical emergency response</p>
        </div>
        <div class="stat-cell">
          <span class="stat-cell__number" style="font-size: 1.35rem;">{content.marketStats.ourClosesPerYear}</span>
          <p class="stat-cell__label">Common construction</p>
        </div>
        <div class="stat-cell">
          <span class="stat-cell__number stat-cell__number--accent" style="font-size: 1.35rem;">{content.marketStats.commonProperty.split(' ').slice(0,3).join(' ')}</span>
          <p class="stat-cell__label">{content.marketStats.commonProperty}</p>
        </div>
      </div>
    </section>
  )}

  <section class="container">
    <span class="section-eyebrow">Coverage</span>
    <h2 style="margin-top:0;">Neighborhoods we serve in {city.name}</h2>
    <p>We run calls across most of {city.name}'s residential areas. The neighborhoods we see most often:</p>
    <ul>
      {content.neighborhoods.map((n) => <li>{n}</li>)}
    </ul>
    <p>If your area isn't listed, call anyway — odds are we cover it too.</p>
    {content.commonZips && (
      <p style="font-size: 0.92rem; color: #6a7080; margin-top: 1rem;">
        <strong>Zip codes we serve:</strong> {content.commonZips.join(", ")}
      </p>
    )}
  </section>

  {content.processDetail && (
    <section class="section--alt">
      <div class="container container--narrow">
        <span class="section-eyebrow">How it works in {city.name}</span>
        <h2 style="margin-top:0;">The process — {city.name}-specific details</h2>
        <p>{content.processDetail}</p>
      </div>
    </section>
  )}

  {content.whyCallUs && (
    <section class="container container--narrow">
      <span class="section-eyebrow">Why people call us</span>
      <h2 style="margin-top:0;">Who calls us in {city.name}, and why</h2>
      <p>{content.whyCallUs}</p>
    </section>
  )}

  <section class="section--alt">
    <div class="container container--narrow">
      <span class="section-eyebrow">Recent jobs</span>
      <h2 style="margin-top:0;">Real {city.name} jobs we handled</h2>
      {content.caseStudies.map((cs) => (
        <div class="case-card">
          <p><strong>Situation:</strong> {cs.situation}</p>
          <p><strong>What we did:</strong> {cs.outcome}</p>
        </div>
      ))}
      <p style="font-size: 0.88rem; color: #6a6a6a; margin-top: 1.2rem;">
        Anonymized details. Identifying information changed; situations and outcomes are accurate to the job pattern.
      </p>
    </div>
  </section>

  <section class="container">
    <h2>Plumbing services we provide in {city.name}</h2>
    <p>The most common calls we run in {city.name}:</p>
    <div class="service-grid">
      {SITE.subVerticals.map((s) => (
        <a href={`/situations/${s.slug}/`} class="service-card">
          <h3>{s.name}</h3>
          <p>{SUBVERTICAL_BLURBS[s.slug] || `${s.name} — fast, licensed, flat-rate.`}</p>
        </a>
      ))}
    </div>
  </section>

  <section class="container container--narrow">
    <h2>Questions from {city.name} homeowners</h2>
    <div class="faq">
      {cityFaqsForSchema.map((f) => (
        <div class="faq__item">
          <p class="faq__q">{f.q}</p>
          <p class="faq__a">{f.a}</p>
        </div>
      ))}
    </div>
    <div class="inline-disclaimer">
      <strong>Licensing:</strong> {SITE.brandName} is an AZ ROC-licensed and bonded plumbing contractor. Verify our standing anytime at roc.az.gov. Flat-rate pricing is provided in writing before any work begins.
    </div>
  </section>

  <section class="container">
    <h2>Other Arizona cities we serve</h2>
    <div class="city-grid">
      {otherCities.map((c) => (
        <a href={`/${c.slug}/`} class="city-tile">{c.name}</a>
      ))}
    </div>
  </section>

  <section class="cta-section">
    <div class="container container--narrow">
      <h2>Plumbing emergency in {city.name}?</h2>
      <p>We answer live, dispatch fast, and quote before we work. Call now for 24-hour service.</p>
      <a href={`tel:${SITE.phone}`} class="btn btn--large">Call {SITE.phoneDisplay}</a>
    </div>
  </section>
</BaseLayout>
