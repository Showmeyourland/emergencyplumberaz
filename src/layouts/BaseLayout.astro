---
import { SITE } from '../config';
import '../styles/brand.css';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  pageType?: 'homepage' | 'city' | 'service' | 'blog' | 'trust';
  schema?: Record<string, any> | Record<string, any>[];
  crumbs?: { label: string; href?: string }[];
}

const { title, description, canonical, ogImage, schema, crumbs } = Astro.props;
const finalCanonical = canonical ?? new URL(Astro.url.pathname, SITE.baseUrl).toString();
const finalOg = ogImage ?? new URL(SITE.ogImage, SITE.baseUrl).toString();
const year = new Date().getFullYear();

// Always include the sitewide LocalBusiness schema
const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": SITE.schemaSubtype,
  "@id": `${SITE.baseUrl}/#org`,
  name: SITE.brandName,
  url: SITE.baseUrl,
  telephone: SITE.phone,
  description: SITE.metaDescription,
  priceRange: "$$",
  address: {
    "@type": "PostalAddress",
    addressLocality: "Phoenix",
    addressRegion: "AZ",
    addressCountry: "US",
  },
  areaServed: SITE.cities.map((c) => ({ "@type": "City", name: c.name, containedInPlace: { "@type": "State", name: "Arizona" } })),
  openingHoursSpecification: [
    {
      "@type": "OpeningHoursSpecification",
      dayOfWeek: ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"],
      opens: "08:00",
      closes: "20:00",
    },
  ],
};

const schemaArray = schema ? (Array.isArray(schema) ? schema : [schema]) : [];
const allSchema = [localBusinessSchema, ...schemaArray];
---
<!doctype html>
<html lang="en-US">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="generator" content={Astro.generator} />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={finalCanonical} />
  <meta name="robots" content="index, follow" />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={finalCanonical} />
  <meta property="og:image" content={finalOg} />
  <meta property="og:site_name" content={SITE.brandName} />
  <meta property="og:locale" content="en_US" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={finalOg} />

  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="sitemap" href="/sitemap-index.xml" />

  {allSchema.map((s) => (
    <script type="application/ld+json" set:html={JSON.stringify(s)} />
  ))}
</head>
<body>
  <header class="site-header">
    <div class="site-header__inner">
      <a href="/" class="site-header__brand">{SITE.brandName}</a>
      <nav class="site-header__nav">
        <a href="/how-it-works/">How It Works</a>
        <a href="/situations/sell-fast-cash/">Sell Fast</a>
        <a href="/about/">About</a>
        <a href={`tel:${SITE.phone}`} class="site-header__phone">{SITE.phoneDisplay}</a>
      </nav>
    </div>
  </header>

  {crumbs && crumbs.length > 0 && (
    <nav class="crumbs container" aria-label="Breadcrumb">
      {crumbs.map((c, i) => (
        <span>
          {c.href ? <a href={c.href}>{c.label}</a> : <span>{c.label}</span>}
          {i < crumbs.length - 1 && <span> &rsaquo; </span>}
        </span>
      ))}
    </nav>
  )}

  <main>
    <slot />
  </main>

  <footer class="site-footer">
    <div class="container">
      <div class="site-footer__grid">
        <div>
          <h4>{SITE.brandName}</h4>
          <p>{SITE.tagline}</p>
          <p><a href={`tel:${SITE.phone}`}>{SITE.phoneDisplay}</a></p>
          <p>{SITE.hours}</p>
        </div>
        <div>
          <h4>Common situations</h4>
          {SITE.subVerticals.map((s) => (
            <p><a href={`/situations/${s.slug}/`}>{s.short}</a></p>
          ))}
        </div>
        <div>
          <h4>Cities we work in</h4>
          {SITE.cities.slice(0, 8).map((c) => (
            <p><a href={`/${c.slug}/`}>{c.name}</a></p>
          ))}
        </div>
        <div>
          <h4>Company</h4>
          <p><a href="/about/">About</a></p>
          <p><a href="/contact/">Contact</a></p>
          <p><a href="/privacy/">Privacy Policy</a></p>
          <p><a href="/terms/">Terms of Service</a></p>
        </div>
      </div>

      <div class="site-footer__legal">
        <p>
          <strong>Licensing:</strong> {SITE.brandName} is an Arizona ROC-licensed and bonded plumbing contractor serving
          Phoenix metro, Tucson, and communities statewide. You can verify our license status, bond, and complaint history
          anytime at roc.az.gov. All field plumbers are trained employees, not subcontracted day labor.
        </p>
        <p>
          <strong>Pricing:</strong> Estimates and quotes are non-binding until work is authorized on site. Emergency and
          after-hours dispatch fees are disclosed before a truck is sent, and repairs are priced on a flat-rate schedule by
          job type — provided to you in writing before any work begins. The price you approve is the price you pay, plus any
          additional scope you authorize in writing if a hidden condition is discovered.
        </p>
        <p>
          This website is informational and does not guarantee service availability, response time, or pricing for any
          specific job; those are confirmed when you call. Contacting {SITE.brandName} through this site does not by itself
          create a service contract.
        </p>
        <p>&copy; {year} {SITE.brandName}. All rights reserved.</p>
      </div>
    </div>
  </footer>

  <a href={`tel:${SITE.phone}`} class="phone-bar">
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
    Call {SITE.phoneDisplay}
  </a>
</body>
</html>
